---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Decorations from '../../../components/Decorations.astro';
import OriginsMap from '../../../components/OriginsMap';
import { t } from '../../../i18n';

const lang = 'ja';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const countries = [
  {
    slug: 'ethiopia',
    name: 'エチオピア',
    nameEn: 'Ethiopia',
    flag: '🇪🇹',
    tagline: 'コーヒー発祥の地',
    flavors: ['フローラル', 'ベリー', 'シトラス'],
    color: 'from-green-800/10 to-amber-800/5',
    image: `${base}/images/origins/ethiopia.jpg`,
  },
  {
    slug: 'kenya',
    name: 'ケニア',
    nameEn: 'Kenya',
    flag: '🇰🇪',
    tagline: '鮮烈な酸とジューシーさ',
    flavors: ['ブラックカラント', 'トマト', 'グレープフルーツ'],
    color: 'from-red-800/10 to-green-800/5',
    image: `${base}/images/origins/kenya.jpg`,
  },
  {
    slug: 'colombia',
    name: 'コロンビア',
    nameEn: 'Colombia',
    flag: '🇨🇴',
    tagline: 'バランスの芸術',
    flavors: ['キャラメル', 'ナッツ', 'レッドアップル'],
    color: 'from-yellow-800/10 to-blue-800/5',
    image: `${base}/images/origins/colombia.jpg`,
  },
];

const comingSoon = [
  { name: 'ブラジル', flag: '🇧🇷' },
  { name: 'グアテマラ', flag: '🇬🇹' },
  { name: 'パナマ', flag: '🇵🇦' },
  { name: 'イエメン', flag: '🇾🇪' },
];
---

<BaseLayout lang={lang} currentPath={`/${lang}/origins`}>
  <!-- Header -->
  <div class="mb-12">
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-xl mb-2 -rotate-1">
      Terroir & Farms
    </p>
    <h1 class="text-4xl md:text-5xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] leading-tight mb-4">
      産地・農園
    </h1>
    <p class="text-lg text-[var(--color-text-light)] max-w-2xl leading-relaxed">
      コーヒーの味わいは、育った土地で決まる。標高、気候、土壌、品種、そして精製法——
      テロワールが生み出す多様なフレーバーを、主要産地ごとに深掘りします。
    </p>
  </div>

  <Decorations type="divider" />

  <!-- Interactive Map -->
  <div class="mb-12">
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-sm mb-3">
      ↓ 国をクリックして産地詳細へ
    </p>
    <OriginsMap client:load lang={lang} base={base} />
  </div>

  <Decorations type="divider" />

  <!-- Country cards -->
  <div class="space-y-6 mb-12">
    {countries.map((country, i) => (
      <a
        href={`${base}/${lang}/origins/${country.slug}`}
        class="block group rounded-2xl border border-[var(--color-border)] overflow-hidden transition-all duration-300 hover:shadow-2xl hover:-translate-y-1"
      >
        <div class="flex flex-col md:flex-row">
          <!-- Image -->
          <div class="md:w-56 h-44 md:h-auto overflow-hidden flex-shrink-0 relative">
            <img
              src={country.image}
              alt={country.name}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-transparent to-[var(--color-card)]/60 hidden md:block" />
          </div>

          <!-- Content -->
          <div class:list={['flex-1 p-6 md:p-8 flex flex-col md:flex-row md:items-center gap-5 bg-gradient-to-r', country.color]}>
            <div class="md:min-w-[180px]">
              <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-sm mb-1">{country.nameEn}</p>
              <h2 class="text-2xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] group-hover:text-[var(--color-accent)] transition-colors">
                {country.name}
              </h2>
              <p class="text-[var(--color-text-light)] text-sm mt-1">{country.tagline}</p>
            </div>

            <div class="flex flex-wrap gap-2 flex-1">
              {country.flavors.map((f) => (
                <span class="text-xs px-3 py-1 rounded-full bg-[var(--color-primary)]/8 text-[var(--color-primary)] font-medium border border-[var(--color-primary)]/10">
                  {f}
                </span>
              ))}
            </div>

            <svg class="w-5 h-5 text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-all shrink-0 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </div>
        </div>
      </a>
    ))}
  </div>

  <Decorations type="beans" />

  <!-- Coming soon -->
  <div class="mb-8">
    <p class="font-[var(--font-accent)] text-xl text-[var(--color-text-light)] mb-4">Coming soon...</p>
    <div class="flex flex-wrap gap-3">
      {comingSoon.map((c) => (
        <div class="flex items-center gap-2 px-4 py-2 rounded-full bg-[var(--color-card)] border border-[var(--color-border)] opacity-50">
          <span class="text-xl">{c.flag}</span>
          <span class="text-sm text-[var(--color-text-light)]">{c.name}</span>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
