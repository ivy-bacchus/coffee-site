---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n';

const lang = 'ja';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sections = [
  {
    key: 'origins',
    title: '産地・農園',
    subtitle: 'Origins & Farms',
    desc: 'エチオピア、ケニア、コロンビア——テロワールが生む多様なフレーバーを深掘り。',
    href: `${base}/${lang}/origins`,
    image: `${base}/images/origins/ethiopia.jpg`,
    badge: 'Terroir',
  },
  {
    key: 'brewing',
    title: '抽出ガイド',
    subtitle: 'Brewing Methods',
    desc: 'V60、エスプレッソ、フレンチプレス——器具ごとの理論とレシピ。',
    href: `${base}/${lang}/brewing`,
    image: `${base}/images/brewing/v60.jpg`,
    badge: 'Pour Over & Espresso',
  },
  {
    key: 'science',
    title: 'コーヒーの化学',
    subtitle: 'Coffee Science',
    desc: '焙煎の化学反応、抽出の物理学——コーヒーの「なぜ」に迫る。',
    href: `${base}/${lang}/science`,
    image: `${base}/images/science/roasting.jpg`,
    badge: 'Chemistry & Physics',
  },
  {
    key: 'processing',
    title: '精製プロセス',
    subtitle: 'Processing Methods',
    desc: 'ウォッシュド、ナチュラル、ハニー——精製法が味に与える影響。',
    href: `${base}/${lang}/processing`,
    image: `${base}/images/processing/natural.jpg`,
    badge: 'Washed · Natural · Honey',
  },
  {
    key: 'tools',
    title: 'レシピ計算機',
    subtitle: 'Tools & Calculator',
    desc: 'ドリッパー別のレシピ計算機。杯数から最適な豆量を即算出。',
    href: `${base}/${lang}/tools`,
    image: `${base}/images/brewing/espresso.jpg`,
    badge: 'Recipe Calculator',
  },
];

const featured = sections[0];
const grid = sections.slice(1);
---

<BaseLayout lang={lang} currentPath={`/${lang}`} fullWidth={true}>

  <!-- ==================== Hero ==================== -->
  <section class="relative h-[88vh] min-h-[540px] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        src={`${base}/images/home/hero.jpg`}
        alt="Coffee"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0" style="background: linear-gradient(to top, #221610 0%, rgba(34,22,16,0.55) 40%, rgba(34,22,16,0.1) 100%);" />
    </div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 md:pb-24 w-full">
      <span class="inline-block px-4 py-1 border border-white/25 rounded-full text-xs font-bold tracking-widest uppercase mb-6 text-white/80 backdrop-blur-sm">
        Specialty Coffee Guide
      </span>
      <h1 class="font-[var(--font-heading)] text-5xl md:text-7xl font-bold text-white leading-[1.1] mb-6">
        コーヒーを、<br />
        <span style="color: #bd490f;">もっと深く。</span>
      </h1>
      <p class="text-lg md:text-xl text-white/65 max-w-lg leading-relaxed mb-10">
        産地・抽出・化学・精製——スペシャルティコーヒーの世界を体系的に学ぶ。
      </p>
      <div class="flex flex-wrap gap-4">
        <a
          href={`${base}/${lang}/origins`}
          class="inline-flex items-center gap-2 text-white font-bold px-8 py-3.5 rounded-xl transition-all hover:brightness-110"
          style="background-color: #bd490f;"
        >
          探索を始める
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href={`${base}/${lang}/tools`}
          class="inline-flex items-center gap-2 text-white font-semibold px-8 py-3.5 rounded-xl border border-white/25 backdrop-blur-sm transition-all hover:bg-white/10"
        >
          レシピ計算機
        </a>
      </div>
    </div>
  </section>

  <!-- ==================== Sections ==================== -->
  <section class="py-24 bg-[var(--color-background)]">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Heading -->
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-2" style="color: #bd490f;">Explore</p>
          <h2 class="font-[var(--font-heading)] text-3xl md:text-4xl font-bold text-[var(--color-dark)]">
            テーマ別に学ぶ
          </h2>
        </div>
        <p class="text-[var(--color-text-muted)] text-sm max-w-xs leading-relaxed">
          5つのテーマから、コーヒーの奥深い世界を探求しましょう。
        </p>
      </div>

      <!-- Featured card -->
      <div class="mb-6">
        <a
          href={featured.href}
          class="group block rounded-2xl overflow-hidden relative shadow-lg hover:shadow-2xl transition-all duration-500"
          style="height: 420px;"
        >
          <img
            src={featured.image}
            alt={featured.title}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(34,22,16,0.85) 0%, rgba(34,22,16,0.4) 60%, transparent 100%);" />
          <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-12">
            <span
              class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide mb-4 text-white w-fit"
              style="background-color: #bd490f;"
            >{featured.badge}</span>
            <h3 class="font-[var(--font-heading)] text-3xl md:text-4xl font-bold text-white mb-2">
              {featured.title}
            </h3>
            <p class="text-white/65 max-w-md text-sm leading-relaxed mb-5">{featured.desc}</p>
            <span class="inline-flex items-center gap-2 text-white/50 text-sm font-semibold group-hover:text-white transition-colors">
              詳しく見る
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>
      </div>

      <!-- Grid: other 4 sections -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {grid.map((section) => (
          <a
            href={section.href}
            class="group block rounded-xl overflow-hidden relative shadow hover:shadow-xl transition-all duration-500"
            style="aspect-ratio: 4/3;"
          >
            <img
              src={section.image}
              alt={section.title}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.05]"
            />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(34,22,16,0.88) 0%, rgba(34,22,16,0.2) 60%, transparent 100%);" />
            <div class="absolute inset-0 flex flex-col justify-end p-5">
              <span class="text-[10px] font-bold uppercase tracking-widest mb-1.5" style="color: #bd490f;">{section.badge}</span>
              <h3 class="font-[var(--font-heading)] text-base font-bold text-white leading-snug">{section.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== Philosophy ==================== -->
  <section class="py-24" style="background-color: #221610;">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">

        <!-- Image -->
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-2xl aspect-square">
            <img
              src={`${base}/images/science/roasting.jpg`}
              alt="Roasting"
              class="w-full h-full object-cover"
            />
          </div>
          <div class="absolute -bottom-5 -right-5 hidden md:block">
            <div class="rounded-2xl p-6 text-white shadow-2xl" style="background-color: #bd490f; max-width: 200px;">
              <p class="text-sm font-[var(--font-heading)] italic leading-snug">
                "豆の声を聴き、秒単位で対話する。それが焙煎です。"
              </p>
            </div>
          </div>
        </div>

        <!-- Text -->
        <div class="text-white">
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #bd490f;">Deep Dive</p>
          <h2 class="font-[var(--font-heading)] text-4xl font-bold mb-6 leading-tight">
            なぜコーヒーは<br />
            <span style="color: #bd490f;">こんなに複雑なのか。</span>
          </h2>
          <p class="text-white/55 mb-10 leading-relaxed text-lg">
            コーヒーには1000種類以上の芳香成分が含まれます。ワインよりも複雑とも言われるこの飲み物を、科学・産地・人の視点から深く理解しましょう。
          </p>
          <div class="space-y-7">
            {[
              {
                title: '産地のテロワール',
                desc: '土壌・標高・気候が生み出す、唯一無二のフレーバー。',
                icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
              },
              {
                title: '化学反応の美学',
                desc: 'メイラード反応、カラメル化——熱が引き出す複雑な香味。',
                icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v11l-4 7h14l-4-7V3"/></svg>`,
              },
              {
                title: '抽出の物理学',
                desc: '水温・粒度・時間のバランスが、一杯の味を決める。',
                icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>`,
              },
            ].map((item) => (
              <div class="flex gap-5">
                <div
                  class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0 text-white"
                  style="background-color: rgba(189,73,15,0.25);"
                  set:html={item.icon}
                />
                <div>
                  <h5 class="font-bold text-white mb-1">{item.title}</h5>
                  <p class="text-white/45 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="py-20 bg-[var(--color-background)]">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 class="font-[var(--font-heading)] text-3xl md:text-4xl font-bold text-[var(--color-dark)] mb-4">
        どこから始めますか？
      </h2>
      <p class="text-[var(--color-text-muted)] mb-10 max-w-md mx-auto leading-relaxed">
        産地から読む？抽出の科学から学ぶ？興味のある入口から始めてください。
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href={`${base}/${lang}/origins`}
          class="px-8 py-3 rounded-xl font-bold text-white transition-all hover:brightness-110"
          style="background-color: #bd490f;"
        >産地を探索する</a>
        <a
          href={`${base}/${lang}/science`}
          class="px-8 py-3 rounded-xl font-semibold border-2 border-[var(--color-border)] text-[var(--color-dark)] hover:border-[#bd490f] transition-all"
        >科学を学ぶ</a>
        <a
          href={`${base}/${lang}/tools`}
          class="px-8 py-3 rounded-xl font-semibold border-2 border-[var(--color-border)] text-[var(--color-dark)] hover:border-[#bd490f] transition-all"
        >計算機を使う</a>
      </div>
    </div>
  </section>

</BaseLayout>
