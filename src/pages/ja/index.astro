---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AmbientOrbs from '../../components/AmbientOrbs.astro';

const lang = 'ja';
---

<BaseLayout lang={lang} currentPath={`/${lang}`} fullWidth={true}>
  <AmbientOrbs />
  <div class="grid-blueprint min-h-screen relative z-10">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-8">

      <!-- Hero (no .reveal — above the fold, always visible) -->
      <section class="py-20 md:py-28 flex flex-col items-start gap-8 relative overflow-hidden">
        <div class="z-10 max-w-3xl">
          <span class="font-bold uppercase tracking-widest text-xs px-3 py-1 rounded-full inline-block mb-6" style="font-family: Manrope, sans-serif; background-color: #c7ebd6; color: #4b6b5b;" data-hero-badge>
            Archive No. 001
          </span>
          <h1 class="text-6xl md:text-7xl font-black italic leading-tight tracking-tighter" style="font-family: 'Noto Serif JP', serif; color: #361f1a;" data-split-text>
            究極の<br/>アーカイブ
          </h1>
          <p class="text-xl mt-8 leading-relaxed" style="color: #504442; font-family: Manrope, sans-serif;" data-hero-sub>
            精度の高い科学的データと、職人の感性が交差する場所。<br class="hidden md:block"/>
            一杯のコーヒーに隠された物理学と芸術を解明する、私たちの記録。
          </p>
        </div>
        <!-- Hero image — 5-photo mosaic parallax panel -->
        <div class="absolute -right-10 top-0 w-1/2 h-full opacity-0 md:opacity-90 pointer-events-none" data-parallax="0.12">
          <div class="w-full h-full transform rotate-1 translate-x-8 translate-y-4 shadow-2xl overflow-hidden" style="border-radius: 0.125rem;">
            <div class="grid grid-cols-2 h-full gap-1">
              <div class="grid grid-rows-2 gap-1">
                <img src="/images/ai-assets/collage/v60-drip.jpg"    alt="V60 ドリップ"   class="w-full h-full object-cover" />
                <img src="/images/ai-assets/collage/espresso-shot.jpg" alt="エスプレッソ" class="w-full h-full object-cover" />
              </div>
              <div class="grid grid-rows-3 gap-1">
                <img src="/images/ai-assets/collage/beans-closeup.jpg"  alt="コーヒー豆"   class="w-full h-full object-cover" />
                <img src="/images/ai-assets/collage/latte-art.jpg"      alt="ラテアート"   class="w-full h-full object-cover" />
                <img src="/images/ai-assets/collage/barista-pouring.jpg" alt="バリスタ"    class="w-full h-full object-cover" />
              </div>
            </div>
          </div>
          <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(244,243,241,0.95) 0%, rgba(244,243,241,0.3) 40%, transparent 70%);"></div>
        </div>
      </section>

      <!-- Bento Grid -->
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 pb-32">

        <!-- 産地・テロワール — 8col -->
        <section class="md:col-span-8 archive-grain relative p-10 md:p-12 overflow-hidden shadow-sm group card-tilt reveal" style="background-color: #f4f3f1;">
          <div class="absolute top-4 right-4 text-[10px] uppercase tracking-widest opacity-40" style="color: #827471; font-family: Manrope, sans-serif;">機密データ // 地形学</div>
          <div class="flex flex-col md:flex-row gap-10 relative z-10">
            <div class="md:w-1/2">
              <h2 class="text-4xl font-black italic leading-tight mb-6" style="font-family: 'Noto Serif JP', serif; color: #361f1a;">
                Terroir<br/>
                <span class="text-2xl font-normal not-italic">テロワールの解剖</span>
              </h2>
              <p class="leading-relaxed mb-8" style="color: #504442; font-family: Manrope, sans-serif;">
                標高、土壌、気候。コーヒー豆のアイデンティティを決定づける環境因子を、地質学的な視点から分析します。エチオピアの火山性土壌からコロンビアの雲霧林まで。
              </p>
              <a href="/ja/origins" class="cta-primary magnetic">
                産地を探索する
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
            <div class="md:w-1/2 relative">
              <img
                src="/images/ai-assets/collage/cherry-hand.jpg"
                alt="コーヒー農園"
                class="w-full object-cover shadow-xl transition-all duration-700 group-hover:grayscale"
                style="aspect-ratio: 4/5; border-radius: 0.125rem;"
              />
              <div class="absolute -bottom-4 -left-4 px-4 py-3" style="background-color: #456555; color: #ffffff; font-family: Manrope, sans-serif; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;">
                標高: 2,100m
              </div>
            </div>
          </div>
          <div class="absolute -bottom-24 -left-24 w-64 h-64 rounded-full" style="border: 0.5px solid rgba(212,195,191,0.3);"></div>
        </section>

        <!-- 精製プロセス — 4col -->
        <section class="md:col-span-4 p-10 flex flex-col justify-between shadow-sm relative group card-tilt reveal reveal-delay-1" style="background-color: #e3e2e0;">
          <div>
            <span class="text-[10px] uppercase font-bold pb-1 mb-6 inline-block" style="color: #4d0b00; border-bottom: 1px solid #4d0b00; font-family: Manrope, sans-serif; letter-spacing: 0.1em;">
              極秘ラボレポート
            </span>
            <h2 class="text-4xl font-black italic leading-tight mt-4" style="font-family: 'Noto Serif JP', serif; color: #361f1a;">
              Processing<br/>
              <span class="text-xl font-normal not-italic">精製プロセス</span>
            </h2>
            <ul class="mt-8 space-y-4 text-sm" style="color: #504442; font-family: Manrope, sans-serif;">
              <li class="flex items-center gap-3"><span class="w-2 h-2 rounded-full flex-shrink-0" style="background-color: #456555;"></span>ウォッシュド（水洗式）</li>
              <li class="flex items-center gap-3"><span class="w-2 h-2 rounded-full flex-shrink-0" style="background-color: #456555;"></span>ナチュラル（天日乾燥）</li>
              <li class="flex items-center gap-3"><span class="w-2 h-2 rounded-full flex-shrink-0" style="background-color: #456555;"></span>アナエロビック（嫌気性発酵）</li>
            </ul>
            <a href="/ja/processing" class="cta-secondary mt-8 magnetic">
              精製法を見る
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="mt-10 overflow-hidden relative" style="border-radius: 0.125rem;">
            <img src="/images/ai-assets/collage/roasting-drum.jpg" alt="コーヒーの精製" class="w-full h-48 object-cover transform scale-110 group-hover:scale-100 transition-transform duration-1000" />
            <div class="absolute inset-0" style="background-color: rgba(54,31,26,0.12); mix-blend-mode: overlay;"></div>
          </div>
        </section>

        <!-- 科学 — 5col -->
        <section class="md:col-span-5 p-8 shadow-lg relative card-tilt reveal-left" style="background-color: #ffffff; border: 1px solid rgba(212,195,191,0.2);">
          <div class="flex justify-between items-start mb-10">
            <h2 class="text-4xl font-black italic leading-tight" style="font-family: 'Noto Serif JP', serif; color: #361f1a;">
              Science<br/><span class="text-xl font-normal not-italic">抽出の物理学</span>
            </h2>
            <svg class="w-10 h-10 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="#456555" stroke-width="1.5"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>
          </div>
          <div class="space-y-5">
            <div class="p-4" style="background-color: #e9e8e5; border-radius: 0.125rem;">
              <div class="flex justify-between text-xs mb-2 font-bold uppercase tracking-widest" style="font-family: Manrope, sans-serif; color: #504442;"><span>抽出収率</span><span>21.4%</span></div>
              <div class="w-full h-1" style="background-color: #d4c3bf;"><div class="h-full" style="width: 80%; background-color: #4d0b00;"></div></div>
            </div>
            <div class="p-4" style="background-color: #e9e8e5; border-radius: 0.125rem;">
              <div class="flex justify-between text-xs mb-2 font-bold uppercase tracking-widest" style="font-family: Manrope, sans-serif; color: #504442;"><span>TDS（濃度）</span><span>1.38%</span></div>
              <div class="w-full h-1" style="background-color: #d4c3bf;"><div class="h-full" style="width: 65%; background-color: #456555;"></div></div>
            </div>
          </div>
          <p class="mt-8 text-sm italic leading-relaxed" style="color: #504442; font-family: Manrope, sans-serif;">
            "黄金比はルールではなく、発見のための土台である。"
          </p>
          <a href="/ja/science" class="cta-secondary mt-6 magnetic">
            科学を探究する
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </section>

        <!-- 抽出ガイド — 7col -->
        <section class="md:col-span-7 flex flex-col md:flex-row shadow-sm overflow-hidden group card-tilt reveal-right" style="background-color: #efeeeb;">
          <div class="md:w-2/3 relative overflow-hidden" style="min-height: 16rem;">
            <img src="/images/ai-assets/collage/v60-drip.jpg" alt="精密な抽出器具" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
          </div>
          <div class="md:w-1/3 p-10 flex flex-col justify-center">
            <h2 class="text-3xl font-black italic mb-4" style="font-family: 'Noto Serif JP', serif; color: #361f1a;">Brewing</h2>
            <p class="text-xs uppercase tracking-tighter mb-5" style="color: #504442; font-family: Manrope, sans-serif;">精密機器と抽出技術</p>
            <p class="text-sm leading-relaxed" style="color: #504442; font-family: Manrope, sans-serif;">マイクロメータ単位での調整が可能なグラインダーから、熱力学的に最適化されたドリッパーまで。</p>
            <a href="/ja/brewing" class="cta-secondary mt-8 self-start magnetic">
              ガイドを見る
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </section>

        <!-- 計算機 — full width, dark -->
        <section class="md:col-span-12 p-12 md:p-20 relative overflow-hidden flex flex-col items-center justify-center text-center reveal-scale" style="background-color: #361f1a;">
          <div class="absolute inset-0 grid-blueprint opacity-10"></div>
          <div class="relative z-10 max-w-2xl">
            <h2 class="text-5xl font-black italic mb-6" style="font-family: 'Noto Serif JP', serif; color: #ffffff;">Calculator</h2>
            <p class="text-lg mb-12 leading-relaxed" style="color: #c19c94; font-family: Manrope, sans-serif;">
              あなたの完璧なレシピを導き出すための、科学的な計算ツール。<br/>豆の量、水量、温度、焙煎度を入力してください。
            </p>
            <div class="flex flex-wrap justify-center gap-4">
              <a href="/ja/tools" class="inline-flex items-center gap-2 px-10 py-4 font-bold tracking-widest text-sm transition-all hover:scale-105 hover:shadow-lg magnetic" style="background-color: #c7ebd6; color: #4b6b5b; font-family: Manrope, sans-serif; border-radius: 0.375rem;">
                レシピ計算機
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
              <a href="/ja/brewing" class="inline-flex items-center gap-2 px-10 py-4 font-bold tracking-widest text-sm hover:bg-white/10 transition-all magnetic" style="border: 1px solid rgba(212,195,191,0.3); color: rgba(255,255,255,0.7); font-family: Manrope, sans-serif; border-radius: 0.375rem;">
                抽出比率ガイド
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
          <div class="absolute top-10 right-10 select-none pointer-events-none" style="color: rgba(255,255,255,0.05); font-size: 10rem;">⚗</div>
        </section>

      </div>
    </div>
  </div>
</BaseLayout>
