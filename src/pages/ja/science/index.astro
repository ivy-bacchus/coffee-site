---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Decorations from '../../../components/Decorations.astro';
import { t } from '../../../i18n';

const lang = 'ja';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const articles = [
  {
    slug: 'roasting-chemistry',
    title: '焙煎の化学',
    titleEn: 'Roasting Chemistry',
    description: 'メイラード反応、カラメル化、ストレッカー分解——生豆が褐色に変わるとき、何が起きているのか。',
    color: 'from-orange-900/10 to-red-900/5',
    image: `${base}/images/science/roasting.jpg`,
    ready: true,
  },
  {
    slug: 'extraction-science',
    title: '抽出の科学',
    titleEn: 'Extraction Science',
    description: '溶解度、TDS、収率。美味しさを数値で捉え、抽出をコントロールするための理論。',
    color: 'from-blue-900/10 to-cyan-900/5',
    image: `${base}/images/science/extraction.jpg`,
    ready: true,
  },
  {
    slug: 'water-chemistry',
    title: '水質と抽出',
    titleEn: 'Water Chemistry',
    description: '硬度、pH、ミネラル組成。コーヒーの98%を占める「水」が味に与える決定的な影響。',
    color: 'from-cyan-900/10 to-blue-900/5',
    image: `${base}/images/science/extraction.jpg`,
    ready: true,
  },
  {
    slug: 'freshness',
    title: '鮮度と劣化',
    titleEn: 'Freshness & Degradation',
    description: '酸化、脱ガス、保存。焙煎後のコーヒーに何が起きているのか。',
    color: 'from-gray-800/10 to-amber-900/5',
    image: `${base}/images/science/roasting.jpg`,
    ready: true,
  },
];
---

<BaseLayout lang={lang} currentPath={`/${lang}/science`}>
  <div class="mb-12">
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-xl mb-2 rotate-[-1deg]">
      Chemistry & Physics
    </p>
    <h1 class="text-4xl md:text-5xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] leading-tight mb-4">
      コーヒーの化学
    </h1>
    <p class="text-lg text-[var(--color-text-light)] max-w-2xl leading-relaxed">
      一杯のコーヒーには、1,000以上の化学物質が含まれている。焙煎で何が起き、抽出で何が溶け出し、
      水がどう関わるのか——コーヒーの味を科学的に解き明かす。
    </p>
  </div>

  <Decorations type="divider" />

  <div class="space-y-5">
    {articles.map((article) => (
      <a
        href={article.ready ? `${base}/${lang}/science/${article.slug}` : undefined}
        class:list={[
          'block group rounded-2xl border border-[var(--color-border)] overflow-hidden transition-all duration-300',
          `bg-gradient-to-r ${article.color}`,
          article.ready
            ? 'hover:shadow-xl hover:-translate-y-1 cursor-pointer'
            : 'opacity-50 cursor-default',
        ]}
      >
        <div class="flex flex-col md:flex-row">
          <div class="md:w-48 h-36 md:h-auto overflow-hidden flex-shrink-0">
            <img
              src={article.image}
              alt={article.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="flex-1 p-6 md:p-8 flex flex-col md:flex-row md:items-center gap-5">
            <div class="flex-1">
              <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-sm mb-1">{article.titleEn}</p>
              <h2 class="text-xl md:text-2xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] group-hover:text-[var(--color-accent)] transition-colors mb-2">
                {article.title}
              </h2>
              <p class="text-[var(--color-text-light)] text-sm leading-relaxed">{article.description}</p>
            </div>
            {!article.ready && (
              <span class="text-xs px-3 py-1 rounded-full bg-[var(--color-secondary)]/15 text-[var(--color-text-light)] border border-[var(--color-secondary)]/20 shrink-0">
                {t(lang, 'common.coming_soon')}
              </span>
            )}
            {article.ready && (
              <svg class="w-5 h-5 text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-all shrink-0 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            )}
          </div>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
