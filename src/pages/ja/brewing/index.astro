---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Decorations from '../../../components/Decorations.astro';
import { t } from '../../../i18n';

const lang = 'ja';

const articles = [
  {
    slug: 'drip',
    title: 'ドリップ',
    titleEn: 'Pour Over',
    description: 'V60、カリタウェーブ、メリタ——ドリッパー形状の違いが抽出に与える影響と、それぞれの最適な淹れ方。',
    icon: '☕',
    color: 'from-amber-900/10 to-orange-900/5',
    ready: true,
  },
  {
    slug: 'immersion',
    title: '浸漬式',
    titleEn: 'Immersion',
    description: 'フレンチプレス、クレバードリッパー——コーヒー粉を湯に浸して抽出する方法の原理と実践。',
    icon: '🫖',
    color: 'from-teal-900/10 to-emerald-900/5',
    ready: true,
  },
  {
    slug: 'espresso',
    title: 'エスプレッソ',
    titleEn: 'Espresso',
    description: '高圧抽出の原理、マシンの構造、ダイヤルイン。9気圧が生み出す濃密な一杯の科学。',
    icon: '☕',
    color: 'from-red-900/10 to-rose-900/5',
    ready: false,
  },
  {
    slug: 'others',
    title: 'その他',
    titleEn: 'Others',
    description: 'サイフォン、エアロプレス、水出し——個性的な抽出器具たちの原理と魅力。',
    icon: '🧪',
    color: 'from-purple-900/10 to-indigo-900/5',
    ready: false,
  },
];
---

<BaseLayout lang={lang} currentPath={`/${lang}/brewing`}>
  <div class="mb-12">
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-xl mb-2 rotate-[-1deg]">
      Brewing Guide
    </p>
    <h1 class="text-4xl md:text-5xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] leading-tight mb-4">
      抽出ガイド
    </h1>
    <p class="text-lg text-[var(--color-text-light)] max-w-2xl leading-relaxed">
      同じ豆でも、抽出方法が変われば味は劇的に変わる。ドリップ、浸漬、エスプレッソ——
      それぞれの原理を理解し、器具ごとの最適なアプローチを学ぶ。
    </p>
  </div>

  <Decorations type="divider" />

  <div class="space-y-5">
    {articles.map((article) => (
      <a
        href={article.ready ? `/${lang}/brewing/${article.slug}` : undefined}
        class:list={[
          'block group rounded-2xl border border-[var(--color-border)] overflow-hidden transition-all duration-300',
          `bg-gradient-to-r ${article.color}`,
          article.ready
            ? 'hover:shadow-xl hover:-translate-y-1 cursor-pointer'
            : 'opacity-50 cursor-default',
        ]}
      >
        <div class="p-6 md:p-8 flex flex-col md:flex-row md:items-center gap-5">
          <span class="text-4xl group-hover:scale-110 transition-transform duration-300">{article.icon}</span>
          <div class="flex-1">
            <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-sm mb-1">{article.titleEn}</p>
            <h2 class="text-xl md:text-2xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] group-hover:text-[var(--color-accent)] transition-colors mb-2">
              {article.title}
            </h2>
            <p class="text-[var(--color-text-light)] text-sm leading-relaxed">{article.description}</p>
          </div>
          {!article.ready && (
            <span class="text-xs px-3 py-1 rounded-full bg-[var(--color-secondary)]/15 text-[var(--color-text-light)] border border-[var(--color-secondary)]/20 shrink-0">
              {t(lang, 'common.coming_soon')}
            </span>
          )}
          {article.ready && (
            <svg class="w-5 h-5 text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-all shrink-0 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          )}
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
