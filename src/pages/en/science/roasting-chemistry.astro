  <tbody>
    <tr>
      <td>Furans</td>
      <td>2-Furfurylthiol</td>
      <td>Classic "coffee" aroma</td>
      <td>Maillard reaction</td>
    </tr>
    <tr>
      <td>Pyrazines</td>
      <td>2-Ethyl-3,5-dimethylpyrazine</td>
      <td>Nutty, roasty</td>
      <td>Maillard reaction</td>
    </tr>
    <tr>
      <td>Aldehydes</td>
      <td>3-Methylbutanal</td>
      <td>Chocolate</td>
      <td>Strecker degradation</td>
    </tr>
    <tr>
      <td>Ketones</td>
