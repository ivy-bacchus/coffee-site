  <thead>
    <tr>
      <th>Type</th>
      <th>Examples</th>
      <th>Holes</th>
      <th>Flow Control</th>
      <th>Even Extraction</th>
      <th>Difficulty</th>
    </tr>
  </thead>
  <tbody>
    <tr>
      <td><strong>Cone</strong></td>
      <td>V60, Origami</td>
      <td>1 large</td>
      <td>Pour technique</td>
      <td>Skill-dependent</td>
      <td>High</td>
    </tr>
