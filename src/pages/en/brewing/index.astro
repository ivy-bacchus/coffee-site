---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Decorations from '../../../components/Decorations.astro';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const articles = [
  {
    slug: 'drip',
    title: 'Pour Over',
    titleEn: 'Pour Over',
    description: 'V60, Kalita Wave, Melitta — how dripper shape affects extraction, and the optimal approach for each.',
    color: 'from-amber-900/10 to-orange-900/5',
    image: `${base}/images/ai-assets/collage/v60-drip.jpg`,
    ready: true,
  },
  {
    slug: 'immersion',
    title: 'Immersion',
    titleEn: 'Immersion',
    description: 'French press, Clever Dripper — the principles and practice of steeping coffee grounds in water.',
    color: 'from-teal-900/10 to-emerald-900/5',
    image: `${base}/images/ai-assets/collage/stirring.jpg`,
    ready: true,
  },
  {
    slug: 'espresso',
    title: 'Espresso',
    titleEn: 'Espresso',
    description: 'High-pressure extraction, machine anatomy, dial-in. The science of a concentrated shot at 9 bar.',
    color: 'from-red-900/10 to-rose-900/5',
    image: `${base}/images/ai-assets/collage/espresso-shot.jpg`,
    ready: true,
  },
  {
    slug: 'others',
    title: 'Others',
    titleEn: 'Others',
    description: 'Siphon, AeroPress, cold brew — the principles and appeal of specialty brewing devices.',
    color: 'from-purple-900/10 to-indigo-900/5',
    image: `${base}/images/ai-assets/collage/drip-kettle-window.jpg`,
    ready: true,
  },
  {
    slug: 'drippers',
    title: 'Dripper Encyclopedia',
    titleEn: 'Dripper Encyclopedia',
    description: 'From V60 to Chemex — history, design philosophy, and extraction characteristics of 10+ drippers compared.',
    color: 'from-amber-900/10 to-orange-900/5',
    image: `${base}/images/ai-assets/collage/chemex-pourover.jpg`,
    ready: true,
  },
  {
    slug: 'grinders',
    title: 'Grinder Guide',
    titleEn: 'Grinder Guide',
    description: 'Flat vs. conical burrs, hand vs. electric — how grind uniformity shapes flavor, and what to buy at every budget.',
    color: 'from-stone-900/10 to-gray-900/5',
    image: `${base}/images/ai-assets/collage/vintage-grinder.jpg`,
    ready: true,
  },
];
---

<BaseLayout lang={lang} currentPath={`/${lang}/brewing`}>
  <div class="mb-12">
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-xl mb-2 rotate-[-1deg]">
      Brewing Guide
    </p>
    <h1 class="text-4xl md:text-5xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] leading-tight mb-4">
      Brewing Guide
    </h1>
    <p class="text-lg text-[var(--color-text-light)] max-w-2xl leading-relaxed">
      The same beans taste dramatically different depending on brew method. Pour over, immersion, espresso —
      understand the principles of each and learn the optimal approach for every tool.
    </p>
  </div>

  <Decorations type="divider" />

  <div class="space-y-5">
    {articles.map((article) => (
      <a
        href={article.ready ? `${base}/${lang}/brewing/${article.slug}` : undefined}
        class:list={[
          'block group rounded-2xl border border-[var(--color-border)] overflow-hidden transition-all duration-300',
          `bg-gradient-to-r ${article.color}`,
          article.ready
            ? 'hover:shadow-xl hover:-translate-y-1 cursor-pointer'
            : 'opacity-50 cursor-default',
        ]}
      >
        <div class="flex flex-col md:flex-row">
          <div class="md:w-48 h-36 md:h-auto overflow-hidden flex-shrink-0">
            <img
              src={article.image}
              alt={article.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="flex-1 p-6 md:p-8 flex flex-col md:flex-row md:items-center gap-5">
            <div class="flex-1">
              <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-sm mb-1">{article.titleEn}</p>
              <h2 class="text-xl md:text-2xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] group-hover:text-[var(--color-accent)] transition-colors mb-2">
                {article.title}
              </h2>
              <p class="text-[var(--color-text-light)] text-sm leading-relaxed">{article.description}</p>
            </div>
            {!article.ready && (
              <span class="text-xs px-3 py-1 rounded-full bg-[var(--color-secondary)]/15 text-[var(--color-text-light)] border border-[var(--color-secondary)]/20 shrink-0">
                Coming Soon
              </span>
            )}
            {article.ready && (
              <svg class="w-5 h-5 text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-all shrink-0 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            )}
          </div>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
