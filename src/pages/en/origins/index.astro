---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import OriginsMap from '../../../components/OriginsMap';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const regions = [
  {
    region: 'Africa',
    countries: [
      {
        slug: 'ethiopia',
        name: 'Ethiopia',
        nameEn: 'Ethiopia',
        flagCode: 'et',
        tagline: 'Birthplace of Coffee',
        flavors: ['Floral', 'Berry', 'Citrus'],
        elevation: '1,500–2,200m',
      },
      {
        slug: 'kenya',
        name: 'Kenya',
        nameEn: 'Kenya',
        flagCode: 'ke',
        tagline: 'Vivid Acidity & Complexity',
        flavors: ['Blackcurrant', 'Tomato', 'Grapefruit'],
        elevation: '1,400–2,000m',
      },
    ],
  },
  {
    region: 'Latin America',
    countries: [
      {
        slug: 'colombia',
        name: 'Colombia',
        nameEn: 'Colombia',
        flagCode: 'co',
        tagline: 'The Art of Balance',
        flavors: ['Caramel', 'Nutty', 'Red Apple'],
        elevation: '1,200–2,000m',
      },
      {
        slug: 'brazil',
        name: 'Brazil',
        nameEn: 'Brazil',
        flagCode: 'br',
        tagline: "World's Largest Producer",
        flavors: ['Nutty', 'Chocolate', 'Caramel'],
        elevation: '800–1,400m',
      },
      {
        slug: 'guatemala',
        name: 'Guatemala',
        nameEn: 'Guatemala',
        flagCode: 'gt',
        tagline: 'Volcanic Soil & Ancient Maya Land',
        flavors: ['Dark Chocolate', 'Spice', 'Dried Fruit'],
        elevation: '1,300–2,000m',
      },
    ],
  },
];

const comingSoonRegions = [
  {
    region: 'Africa',
    countries: [
      { name: 'Tanzania',  flagCode: 'tz' },
    ],
  },
  {
    region: 'Latin America',
    countries: [
      { name: 'Panama',      flagCode: 'pa' },
      { name: 'Costa Rica',  flagCode: 'cr' },
      { name: 'El Salvador', flagCode: 'sv' },
      { name: 'Peru',        flagCode: 'pe' },
      { name: 'Honduras',    flagCode: 'hn' },
      { name: 'Nicaragua',   flagCode: 'ni' },
      { name: 'Jamaica',     flagCode: 'jm' },
    ],
  },
  {
    region: 'Asia & Middle East',
    countries: [
      { name: 'Indonesia', flagCode: 'id' },
      { name: 'Yemen',     flagCode: 'ye' },
    ],
  },
];
---

<BaseLayout lang={lang} currentPath={`/${lang}/origins`}>
  <!-- Header -->
  <div class="mb-12 reveal">
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-xl mb-2 -rotate-1">
      Terroir & Farms
    </p>
    <h1 class="text-4xl md:text-5xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] leading-tight mb-4">
      Origins & Farms
    </h1>
    <p class="text-lg text-[var(--color-text-light)] max-w-2xl leading-relaxed">
      Coffee flavor is shaped by where it grows. Altitude, climate, soil, variety, and processing —
      explore how terroir creates diverse flavors across the world's key origins.
    </p>
  </div>

  <!-- Interactive Map -->
  <div class="mb-12 reveal">
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-sm mb-3">
      ↓ Click a country to explore
    </p>
    <OriginsMap client:load lang={lang} base={base} />
  </div>

  <!-- Country cards by region -->
  {regions.map((regionGroup) => (
    <div class="mb-14">
      <!-- Region label -->
      <div class="flex items-center gap-3 mb-6 reveal">
        <div class="w-1 h-7 rounded-full shrink-0" style="background-color: #bd490f;" />
        <p class="text-base font-black uppercase tracking-wide leading-none" style="font-family: 'Work Sans', sans-serif; color: var(--color-dark);">{regionGroup.region}</p>
        <div class="flex-1 h-px bg-[var(--color-border)] ml-2" />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {regionGroup.countries.map((country, i) => (
          <a
            href={`${base}/${lang}/origins/${country.slug}`}
            class:list={['group block rounded-2xl overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl reveal', `reveal-delay-${i + 1}`]}
            style="border: 1px solid var(--color-border);"
          >
            {/* Card top — subtle gradient with small flag */}
            <div class="relative px-6 pt-6 pb-10" style="background: linear-gradient(135deg, #3d2218 0%, #2a1610 60%, #1a0f08 100%);">
              {/* Small circular flag */}
              <div class="w-10 h-10 rounded-full overflow-hidden border-2 shadow-md mb-4" style="border-color: rgba(255,255,255,0.2);">
                <img
                  src={`https://flagcdn.com/w160/${country.flagCode}.png`}
                  alt={`${country.name} flag`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              <p class="text-[10px] font-bold uppercase tracking-widest mb-1" style="color: rgba(255,255,255,0.4);">{country.nameEn}</p>
              <h2 class="text-2xl font-black leading-tight" style="font-family: 'Work Sans', sans-serif; color: #ffffff;">{country.name}</h2>
              {/* Hover arrow */}
              <div
                class="absolute top-5 right-5 w-8 h-8 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300"
                style="background-color: rgba(189,73,15,0.85);"
              >
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
            {/* Card body */}
            <div class="px-6 py-5" style="background-color: var(--color-surface-lowest);">
              <p class="text-sm mb-3" style="color: var(--color-text-light);">{country.tagline}</p>
              <div class="flex items-center gap-2 mb-4">
                <svg class="w-3.5 h-3.5 shrink-0" style="color: var(--color-secondary);" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 22h20L12 2z"/></svg>
                <span class="text-xs font-semibold" style="color: var(--color-text-muted);">Elevation {country.elevation}</span>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {country.flavors.map((f) => (
                  <span
                    class="text-xs px-2.5 py-0.5 rounded-full font-semibold"
                    style="background-color: rgba(189,73,15,0.08); color: #bd490f; border: 1px solid rgba(189,73,15,0.2);"
                  >
                    {f}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  ))}

  <!-- Coming soon section by region -->
  <div class="mb-4">
    <div class="flex items-center gap-4 mb-8 reveal">
      <div class="flex-1 h-px bg-[var(--color-border)]" />
      <p class="text-xs font-bold tracking-widest uppercase text-[var(--color-text-muted)]">Coming Soon</p>
      <div class="flex-1 h-px bg-[var(--color-border)]" />
    </div>

    {comingSoonRegions.map((regionGroup) => (
      <div class="mb-6 reveal">
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-3 pl-1">{regionGroup.region}</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
          {regionGroup.countries.map((c) => (
            <div
              class="flex items-center gap-3 px-4 py-3 rounded-xl cursor-default transition-colors"
              style="border: 1px solid var(--color-border); background-color: var(--color-surface-low);"
            >
              <div class="w-7 h-7 rounded-full overflow-hidden shrink-0 border" style="border-color: var(--color-border);">
                <img
                  src={`https://flagcdn.com/w80/${c.flagCode}.png`}
                  alt={`${c.name} flag`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
              <div>
                <p class="text-xs font-bold leading-tight" style="color: var(--color-text-light);">{c.name}</p>
                <p class="text-[10px]" style="color: var(--color-text-muted);">Soon</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>

  <!-- Scroll reveal observer -->
  <script>
    const observer = new IntersectionObserver(
      (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } }),
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
  </script>
</BaseLayout>
