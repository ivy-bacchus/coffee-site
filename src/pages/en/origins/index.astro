---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import OriginsMap from '../../../components/OriginsMap';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const regions = [
  {
    region: 'Africa',
    countries: [
      {
        slug: 'ethiopia',
        name: 'Ethiopia',
        nameEn: 'Ethiopia',
        flagCode: 'et',
        tagline: 'Birthplace of Coffee',
        flavors: ['Floral', 'Berry', 'Citrus'],
      },
      {
        slug: 'kenya',
        name: 'Kenya',
        nameEn: 'Kenya',
        flagCode: 'ke',
        tagline: 'Vivid Acidity & Complexity',
        flavors: ['Blackcurrant', 'Tomato', 'Grapefruit'],
      },
    ],
  },
  {
    region: 'Latin America',
    countries: [
      {
        slug: 'colombia',
        name: 'Colombia',
        nameEn: 'Colombia',
        flagCode: 'co',
        tagline: 'The Art of Balance',
        flavors: ['Caramel', 'Nutty', 'Red Apple'],
      },
      {
        slug: 'brazil',
        name: 'Brazil',
        nameEn: 'Brazil',
        flagCode: 'br',
        tagline: "World's Largest Producer",
        flavors: ['Nutty', 'Chocolate', 'Caramel'],
      },
      {
        slug: 'guatemala',
        name: 'Guatemala',
        nameEn: 'Guatemala',
        flagCode: 'gt',
        tagline: 'Volcanic Soil & Ancient Maya Land',
        flavors: ['Dark Chocolate', 'Spice', 'Dried Fruit'],
      },
    ],
  },
];

const comingSoonRegions = [
  {
    region: 'Africa',
    countries: [
      { name: 'Tanzania',  flagCode: 'tz' },
    ],
  },
  {
    region: 'Latin America',
    countries: [
      { name: 'Panama',      flagCode: 'pa' },
      { name: 'Costa Rica',  flagCode: 'cr' },
      { name: 'El Salvador', flagCode: 'sv' },
      { name: 'Peru',        flagCode: 'pe' },
      { name: 'Honduras',    flagCode: 'hn' },
      { name: 'Nicaragua',   flagCode: 'ni' },
      { name: 'Jamaica',     flagCode: 'jm' },
    ],
  },
  {
    region: 'Asia & Middle East',
    countries: [
      { name: 'Indonesia', flagCode: 'id' },
      { name: 'Yemen',     flagCode: 'ye' },
    ],
  },
];
---

<BaseLayout lang={lang} currentPath={`/${lang}/origins`}>
  <!-- Header -->
  <div class="mb-12">
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-xl mb-2 -rotate-1">
      Terroir & Farms
    </p>
    <h1 class="text-4xl md:text-5xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] leading-tight mb-4">
      Origins & Farms
    </h1>
    <p class="text-lg text-[var(--color-text-light)] max-w-2xl leading-relaxed">
      Coffee flavor is shaped by where it grows. Altitude, climate, soil, variety, and processing —
      explore how terroir creates diverse flavors across the world's key origins.
    </p>
  </div>

  <!-- Interactive Map -->
  <div class="mb-12">
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-sm mb-3">
      ↓ Click a country to explore
    </p>
    <OriginsMap client:load lang={lang} base={base} />
  </div>

  <!-- Country cards by region -->
  {regions.map((regionGroup) => (
    <div class="mb-14">
      <!-- Region label -->
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-7 rounded-full shrink-0" style="background-color: #bd490f;" />
        <p class="text-base font-black uppercase tracking-wide leading-none" style="font-family: 'Work Sans', sans-serif; color: var(--color-dark);">{regionGroup.region}</p>
        <div class="flex-1 h-px bg-[var(--color-border)] ml-2" />
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {regionGroup.countries.map((country) => (
          <a
            href={`${base}/${lang}/origins/${country.slug}`}
            class="group relative overflow-hidden rounded-2xl block"
            style="aspect-ratio: 3/2;"
          >
            <!-- Flag image -->
            <img
              src={`https://flagcdn.com/w640/${country.flagCode}.png`}
              alt={`${country.name} flag`}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.06]"
              style="opacity: 0.65; filter: saturate(0.75);"
              loading="lazy"
            />
            <!-- Brown tint overlay -->
            <div class="absolute inset-0" style="background: rgba(40,20,10,0.3);" />
            <!-- Diagonal half-shadow gradient -->
            <div
              class="absolute inset-0"
              style="background: linear-gradient(160deg, transparent 20%, rgba(20,10,5,0.5) 48%, rgba(20,10,5,0.95) 76%);"
            />
            <!-- Hover arrow -->
            <div
              class="absolute top-4 right-4 w-8 h-8 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-300 translate-x-1 group-hover:translate-x-0"
              style="background-color: rgba(189,73,15,0.85);"
            >
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
            <!-- Text content at bottom -->
            <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6">
              <p
                class="text-xs font-bold uppercase tracking-widest mb-1"
                style="color: rgba(255,255,255,0.6);"
              >{country.nameEn}</p>
              <h2
                class="text-2xl font-black mb-1 leading-tight"
                style="font-family: 'Work Sans', sans-serif; color: #ffffff; letter-spacing: -0.01em;"
              >{country.name}</h2>
              <p
                class="text-sm mb-3"
                style="color: rgba(255,255,255,0.85);"
              >{country.tagline}</p>
              <div class="flex flex-wrap gap-1.5">
                {country.flavors.map((f) => (
                  <span
                    class="text-xs px-2.5 py-0.5 rounded-full font-semibold"
                    style="background-color: rgba(189,73,15,0.35); color: #fcd9c0; border: 1px solid rgba(189,73,15,0.5);"
                  >
                    {f}
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  ))}

  <!-- Coming soon section by region -->
  <div class="mb-4">
    <div class="flex items-center gap-4 mb-8">
      <div class="flex-1 h-px bg-[var(--color-border)]" />
      <p class="text-xs font-bold tracking-widest uppercase text-[var(--color-text-muted)]">Coming Soon</p>
      <div class="flex-1 h-px bg-[var(--color-border)]" />
    </div>

    {comingSoonRegions.map((regionGroup) => (
      <div class="mb-6">
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-3 pl-1">{regionGroup.region}</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
          {regionGroup.countries.map((c) => (
            <div class="relative overflow-hidden rounded-xl cursor-default" style="aspect-ratio: 3/2;">
              <img
                src={`https://flagcdn.com/w320/${c.flagCode}.png`}
                alt={`${c.name} flag`}
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
              />
              <div class="absolute inset-0" style="background: rgba(20,10,5,0.68);" />
              <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(20,10,5,0.95) 0%, transparent 60%);" />
              <div class="absolute top-2 right-2">
                <span
                  class="text-[10px] font-bold px-2 py-0.5 rounded-full"
                  style="background-color: rgba(20,10,5,0.7); color: rgba(255,255,255,0.4); border: 1px solid rgba(255,255,255,0.12);"
                >
                  Soon
                </span>
              </div>
              <div class="absolute bottom-0 left-0 right-0 p-3">
                <p
                  class="text-xs font-bold leading-tight"
                  style="color: rgba(255,255,255,0.65);"
                >{c.name}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>
