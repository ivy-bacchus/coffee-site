---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionCard from '../../components/SectionCard.astro';
import Decorations from '../../components/Decorations.astro';
import { t } from '../../i18n';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout lang={lang} currentPath={`/${lang}`}>
  <!-- Hero Section -->
  <div class="relative mb-16 pt-4">
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-xl md:text-2xl mb-3 -rotate-2 ml-4">
      specialty coffee guide
    </p>

    <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] leading-[1.1] mb-6">
      Dive Deeper<br />
      <span class="text-[var(--color-accent)]">into Coffee.</span>
    </h1>

    <p class="text-lg md:text-xl text-[var(--color-text-light)] max-w-xl leading-relaxed mb-8">
      {t(lang, 'home.hero_subtitle')}
    </p>

    <div class="absolute top-0 right-8 opacity-40 hidden md:block">
      <Decorations type="steam" />
    </div>
  </div>

  <Decorations type="divider" />

  <div class="text-center my-10">
    <p class="font-[var(--font-accent)] text-3xl text-[var(--color-primary)] mb-1">
      Menu
    </p>
    <p class="text-xs text-[var(--color-text-light)] tracking-[0.3em] uppercase">
      what would you like to explore?
    </p>
  </div>

  <!-- Bento grid -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
    <SectionCard
      title={t(lang, 'home.section_origins')}
      description={t(lang, 'home.section_origins_desc')}
      href={`${base}/${lang}/origins`}
      icon="🌍"
      accentLabel="Terroir & Farms"
      variant="featured"
      gradient="from-emerald-900/8 to-amber-900/3"
    />
    <SectionCard
      title={t(lang, 'home.section_science')}
      description={t(lang, 'home.section_science_desc')}
      href={`${base}/${lang}/science`}
      icon="🔬"
      comingSoon
      accentLabel={t(lang, 'common.coming_soon')}
      gradient="from-blue-900/5 to-transparent"
    />
    <SectionCard
      title={t(lang, 'home.section_brewing')}
      description={t(lang, 'home.section_brewing_desc')}
      href={`${base}/${lang}/brewing`}
      icon="💧"
      comingSoon
      accentLabel={t(lang, 'common.coming_soon')}
      gradient="from-cyan-900/5 to-transparent"
    />
  </div>

  <Decorations type="beans" />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-8">
    <SectionCard
      title={t(lang, 'home.section_processing')}
      description={t(lang, 'home.section_processing_desc')}
      href={`${base}/${lang}/processing`}
      icon="🫘"
      comingSoon
      accentLabel={t(lang, 'common.coming_soon')}
      gradient="from-orange-900/5 to-transparent"
    />
    <SectionCard
      title={t(lang, 'home.section_tools')}
      description={t(lang, 'home.section_tools_desc')}
      href={`${base}/${lang}/tools`}
      icon="⚖️"
      comingSoon
      accentLabel={t(lang, 'common.coming_soon')}
      gradient="from-amber-800/5 to-transparent"
    />
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
    <SectionCard
      title={t(lang, 'home.section_cupping')}
      description={t(lang, 'home.section_cupping_desc')}
      href={`${base}/${lang}/cupping`}
      icon="👅"
      variant="compact"
      comingSoon
      accentLabel={t(lang, 'common.coming_soon')}
      gradient="from-rose-900/5 to-transparent"
    />
    <SectionCard
      title={t(lang, 'home.section_varieties')}
      description={t(lang, 'home.section_varieties_desc')}
      href={`${base}/${lang}/varieties`}
      icon="🌱"
      variant="compact"
      comingSoon
      accentLabel={t(lang, 'common.coming_soon')}
      gradient="from-green-900/5 to-transparent"
    />
    <div class="rounded-2xl border border-dashed border-[var(--color-secondary)]/30 p-5 flex flex-col items-center justify-center text-center bg-gradient-to-br from-[var(--color-secondary)]/5 to-transparent">
      <span class="text-2xl mb-2">✨</span>
      <p class="font-[var(--font-accent)] text-lg text-[var(--color-secondary)]">
        More coming soon...
      </p>
      <p class="text-xs text-[var(--color-text-light)] mt-1">
        New content in preparation
      </p>
    </div>
  </div>

  <Decorations type="divider" />

  <div class="text-center py-8">
    <blockquote class="font-[var(--font-heading)] text-xl md:text-2xl italic text-[var(--color-primary)]/70 max-w-lg mx-auto">
      "Coffee is a lot more than just a drink; it's something happening."
    </blockquote>
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] mt-3 text-lg">
      — Gertrude Stein
    </p>
  </div>
</BaseLayout>
