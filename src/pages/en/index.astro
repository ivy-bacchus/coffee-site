---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sections = [
  {
    key: 'origins',
    title: 'Origins & Farms',
    desc: 'Ethiopia, Kenya, Colombia — explore how terroir shapes flavor.',
    href: `${base}/${lang}/origins`,
    image: `${base}/images/origins/ethiopia.jpg`,
    badge: 'Terroir',
  },
  {
    key: 'brewing',
    title: 'Brewing Guide',
    desc: 'V60, espresso, French press — theory and recipes by method.',
    href: `${base}/${lang}/brewing`,
    image: `${base}/images/brewing/v60.jpg`,
    badge: 'Pour Over & Espresso',
  },
  {
    key: 'science',
    title: 'Coffee Science',
    desc: 'Roasting chemistry, extraction physics — the "why" behind flavor.',
    href: `${base}/${lang}/science`,
    image: `${base}/images/science/roasting.jpg`,
    badge: 'Chemistry & Physics',
  },
  {
    key: 'processing',
    title: 'Processing Methods',
    desc: 'Washed, natural, honey — how processing shapes the cup.',
    href: `${base}/${lang}/processing`,
    image: `${base}/images/processing/natural.jpg`,
    badge: 'Washed · Natural · Honey',
  },
  {
    key: 'tools',
    title: 'Recipe Calculator',
    desc: 'Select a dripper and cup count — get instant brew ratios.',
    href: `${base}/${lang}/tools`,
    image: `${base}/images/brewing/espresso.jpg`,
    badge: 'Recipe Calculator',
  },
];

const featured = sections[0];
const grid = sections.slice(1);

const features = [
  {
    title: 'Expert Content',
    desc: 'Systematically structured articles covering varieties, processing, roasting, and extraction science.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>`,
  },
  {
    title: 'Scientific Approach',
    desc: 'Go beyond the surface. Analyze the Maillard reaction, pressure curves, and the physics of water extraction.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v11l-4 7h14l-4-7V3"/></svg>`,
  },
  {
    title: 'Sensory Training',
    desc: 'Refine your palate — understand flavor development through chemistry, terroir, and processing.',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>`,
  },
];
---

<BaseLayout lang={lang} currentPath={`/${lang}`} fullWidth={true}>

  <!-- Hero -->
  <section class="relative h-[85vh] w-full overflow-hidden" style="min-height: 560px;">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: linear-gradient(to right, rgba(34,22,16,0.88) 0%, rgba(34,22,16,0.5) 55%, rgba(34,22,16,0.15) 100%), url('${base}/images/home/hero.jpg');`}
    />
    <div class="relative h-full flex items-center px-6 md:px-20 max-w-[1400px] mx-auto">
      <div class="max-w-2xl space-y-8">
        <div class="space-y-5">
          <span
            class="inline-block px-3 py-1 text-xs font-bold tracking-widest uppercase rounded"
            style="background-color: rgba(189,73,15,0.25); color: #bd490f;"
          >
            Specialty Coffee Guide
          </span>
          <h1
            class="text-6xl md:text-8xl font-black leading-tight text-white"
            style="font-family: 'Work Sans', sans-serif; text-shadow: 0 2px 4px rgba(0,0,0,0.4);"
          >
            Dive Deeper<br />
            <span style="color: #bd490f; font-style: italic;">into Coffee.</span>
          </h1>
          <p class="text-lg md:text-xl font-light max-w-lg leading-relaxed" style="color: rgba(255,255,255,0.7);">
            Origins, brewing, chemistry, processing — a systematic guide to the world of specialty coffee.
          </p>
        </div>
        <div class="flex flex-wrap gap-4">
          <a
            href={`${base}/${lang}/origins`}
            class="inline-flex items-center gap-2 text-white text-base font-bold px-10 py-4 rounded-full transition-all hover:brightness-110"
            style="background-color: #bd490f;"
          >
            Start Exploring
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href={`${base}/${lang}/tools`}
            class="inline-flex items-center gap-2 text-white text-base font-medium px-10 py-4 rounded-full border backdrop-blur-sm transition-all hover:bg-white/10"
            style="border-color: rgba(255,255,255,0.25);"
          >
            Recipe Calculator
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Theme-based Learning -->
  <section class="py-24 px-6 md:px-20 bg-[var(--color-background)]">
    <div class="max-w-[1200px] mx-auto">

      <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
        <div class="max-w-xl">
          <p class="text-xs font-bold tracking-widest uppercase mb-3" style="color: #bd490f;">Explore</p>
          <h2
            class="text-4xl md:text-5xl font-black tracking-tight text-[var(--color-dark)]"
            style="font-family: 'Work Sans', sans-serif;"
          >
            Theme-based Learning
          </h2>
          <p class="text-[var(--color-text-muted)] text-lg mt-3">Curated paths focusing on specific disciplines of coffee.</p>
        </div>
      </div>

      <!-- Featured card (Origins) -->
      <div class="mb-6">
        <a
          href={featured.href}
          class="group block rounded-2xl overflow-hidden relative shadow-lg hover:shadow-2xl transition-all duration-500"
          style="height: 420px;"
        >
          <img
            src={featured.image}
            alt={featured.title}
            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
          />
          <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(34,22,16,0.92) 0%, rgba(34,22,16,0.55) 55%, rgba(34,22,16,0.1) 100%);" />
          <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-12">
            <span
              class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide mb-4 text-white w-fit"
              style="background-color: #bd490f;"
            >{featured.badge}</span>
            <h3
              class="text-3xl md:text-4xl font-black text-white mb-3"
              style="font-family: 'Work Sans', sans-serif;"
            >{featured.title}</h3>
            <p class="max-w-md text-sm leading-relaxed mb-5" style="color: rgba(255,255,255,0.65);">{featured.desc}</p>
            <span class="inline-flex items-center gap-2 text-sm font-semibold transition-colors group-hover:text-white" style="color: rgba(255,255,255,0.5);">
              Explore
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>
      </div>

      <!-- Vertical cards grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {grid.map((section) => (
          <a
            href={section.href}
            class="group relative overflow-hidden rounded-xl bg-slate-800 transition-all duration-300 hover:-translate-y-2 block"
            style="aspect-ratio: 3/4;"
          >
            <img
              src={section.image}
              alt={section.title}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(34,22,16,0.92) 0%, rgba(34,22,16,0.3) 55%, transparent 100%);" />
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <span class="text-[10px] font-bold uppercase tracking-widest block mb-2" style="color: rgba(255,255,255,0.45);">{section.badge}</span>
              <h3
                class="text-xl font-bold text-white mb-1"
                style="font-family: 'Work Sans', sans-serif;"
              >{section.title}</h3>
              <p class="text-sm leading-relaxed" style="color: rgba(255,255,255,0.6);">{section.desc}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Deepen Your Knowledge -->
  <section class="py-24 px-6 md:px-20" style="background-color: rgba(189,73,15,0.07);">
    <div class="max-w-[1200px] mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <div class="space-y-8">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #bd490f;">Deep Dive</p>
          <h2
            class="text-4xl md:text-5xl font-black tracking-tight leading-tight text-[var(--color-dark)]"
            style="font-family: 'Work Sans', sans-serif;"
          >
            Why is coffee<br />
            <span style="color: #bd490f;">so complex?</span>
          </h2>
          <p class="text-[var(--color-text-muted)] text-lg mt-4 leading-relaxed">
            Coffee contains over 1,000 aromatic compounds — more complex than wine. Explore it through science, origin, and craft.
          </p>
        </div>

        <div class="space-y-7">
          {features.map((item) => (
            <div class="flex gap-5 items-start">
              <div
                class="p-3 rounded-lg shrink-0 text-white"
                style="background-color: #bd490f;"
                set:html={item.icon}
              />
              <div>
                <h4 class="font-bold text-[var(--color-dark)] mb-1">{item.title}</h4>
                <p class="text-[var(--color-text-muted)] text-sm leading-relaxed">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="aspect-square rounded-2xl overflow-hidden shadow-2xl">
          <img
            src={`${base}/images/science/roasting.jpg`}
            alt="Roasting"
            class="w-full h-full object-cover"
          />
        </div>
        <div
          class="absolute -bottom-6 -left-6 p-6 rounded-xl shadow-xl hidden md:block"
          style="background-color: white; border: 1px solid rgba(189,73,15,0.2);"
        >
          <p class="text-3xl font-black" style="color: #bd490f; font-family: 'Work Sans', sans-serif;">1,000+</p>
          <p class="text-xs font-bold tracking-widest uppercase text-slate-400 mt-1">Aroma Compounds</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6" style="background-color: #221610;">
    <div class="max-w-[1200px] mx-auto text-center">
      <h2
        class="text-3xl md:text-4xl font-black tracking-tight text-white mb-4"
        style="font-family: 'Work Sans', sans-serif;"
      >
        Where will you start?
      </h2>
      <p class="mb-10 max-w-md mx-auto leading-relaxed" style="color: rgba(255,255,255,0.45);">
        Start with origins, the science, or jump straight to brewing recipes.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a
          href={`${base}/${lang}/origins`}
          class="px-8 py-3.5 rounded-full font-bold text-white transition-all hover:brightness-110"
          style="background-color: #bd490f;"
        >Explore Origins</a>
        <a
          href={`${base}/${lang}/science`}
          class="px-8 py-3.5 rounded-full font-semibold border text-white hover:bg-white/10 transition-all"
          style="border-color: rgba(255,255,255,0.2);"
        >Study the Science</a>
        <a
          href={`${base}/${lang}/tools`}
          class="px-8 py-3.5 rounded-full font-semibold border text-white hover:bg-white/10 transition-all"
          style="border-color: rgba(255,255,255,0.2);"
        >Use the Calculator</a>
      </div>
    </div>
  </section>

</BaseLayout>
