---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sections = [
  {
    key: 'origins',
    title: 'Origins & Farms',
    desc: 'Ethiopia, Kenya, Colombia — explore how terroir shapes flavor.',
    href: `${base}/${lang}/origins`,
    image: `${base}/images/origins/ethiopia.jpg`,
    badge: 'Terroir',
  },
  {
    key: 'brewing',
    title: 'Brewing Guide',
    desc: 'V60, espresso, French press — theory and recipes by method.',
    href: `${base}/${lang}/brewing`,
    image: `${base}/images/brewing/v60.jpg`,
    badge: 'Pour Over & Espresso',
  },
  {
    key: 'science',
    title: 'Coffee Science',
    desc: 'Roasting chemistry, extraction physics — the "why" behind flavor.',
    href: `${base}/${lang}/science`,
    image: `${base}/images/science/roasting.jpg`,
    badge: 'Chemistry & Physics',
  },
  {
    key: 'processing',
    title: 'Processing Methods',
    desc: 'Washed, natural, honey — how processing shapes the cup.',
    href: `${base}/${lang}/processing`,
    image: `${base}/images/processing/natural.jpg`,
    badge: 'Washed · Natural · Honey',
  },
  {
    key: 'tools',
    title: 'Recipe Calculator',
    desc: 'Select a dripper and cup count — get instant brew ratios.',
    href: `${base}/${lang}/tools`,
    image: `${base}/images/brewing/espresso.jpg`,
    badge: 'Recipe Calculator',
  },
];

const featured = sections[0];
const grid = sections.slice(1);
---

<BaseLayout lang={lang} currentPath={`/${lang}`} fullWidth={true}>

  <!-- Hero -->
  <section class="relative h-[88vh] min-h-[540px] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img src={`${base}/images/home/hero.jpg`} alt="Coffee" class="w-full h-full object-cover" />
      <div class="absolute inset-0" style="background: linear-gradient(to top, #221610 0%, rgba(34,22,16,0.55) 40%, rgba(34,22,16,0.1) 100%);" />
    </div>
    <div class="relative z-10 max-w-7xl mx-auto px-6 pb-16 md:pb-24 w-full">
      <span class="inline-block px-4 py-1 border border-white/25 rounded-full text-xs font-bold tracking-widest uppercase mb-6 text-white/80 backdrop-blur-sm">
        Specialty Coffee Guide
      </span>
      <h1 class="font-[var(--font-heading)] text-5xl md:text-7xl font-bold text-white leading-[1.1] mb-6">
        Dive Deeper<br />
        <span style="color: #bd490f;">into Coffee.</span>
      </h1>
      <p class="text-lg md:text-xl text-white/65 max-w-lg leading-relaxed mb-10">
        Origins, brewing, chemistry, processing — a systematic guide to the world of specialty coffee.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href={`${base}/${lang}/origins`} class="inline-flex items-center gap-2 text-white font-bold px-8 py-3.5 rounded-xl transition-all hover:brightness-110" style="background-color: #bd490f;">
          Start Exploring
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href={`${base}/${lang}/tools`} class="inline-flex items-center gap-2 text-white font-semibold px-8 py-3.5 rounded-xl border border-white/25 backdrop-blur-sm transition-all hover:bg-white/10">
          Recipe Calculator
        </a>
      </div>
    </div>
  </section>

  <!-- Sections -->
  <section class="py-24 bg-[var(--color-background)]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-6">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase mb-2" style="color: #bd490f;">Explore</p>
          <h2 class="font-[var(--font-heading)] text-3xl md:text-4xl font-bold text-[var(--color-dark)]">Learn by Topic</h2>
        </div>
        <p class="text-[var(--color-text-muted)] text-sm max-w-xs leading-relaxed">
          Five themes to explore the depth of specialty coffee.
        </p>
      </div>

      <div class="mb-6">
        <a href={featured.href} class="group block rounded-2xl overflow-hidden relative shadow-lg hover:shadow-2xl transition-all duration-500" style="height: 420px;">
          <img src={featured.image} alt={featured.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" />
          <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(34,22,16,0.85) 0%, rgba(34,22,16,0.4) 60%, transparent 100%);" />
          <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-12">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide mb-4 text-white w-fit" style="background-color: #bd490f;">{featured.badge}</span>
            <h3 class="font-[var(--font-heading)] text-3xl md:text-4xl font-bold text-white mb-2">{featured.title}</h3>
            <p class="text-white/65 max-w-md text-sm leading-relaxed mb-5">{featured.desc}</p>
            <span class="inline-flex items-center gap-2 text-white/50 text-sm font-semibold group-hover:text-white transition-colors">
              Explore
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {grid.map((section) => (
          <a href={section.href} class="group block rounded-xl overflow-hidden relative shadow hover:shadow-xl transition-all duration-500" style="aspect-ratio: 4/3;">
            <img src={section.image} alt={section.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.05]" />
            <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(34,22,16,0.88) 0%, rgba(34,22,16,0.2) 60%, transparent 100%);" />
            <div class="absolute inset-0 flex flex-col justify-end p-5">
              <span class="text-[10px] font-bold uppercase tracking-widest mb-1.5" style="color: #bd490f;">{section.badge}</span>
              <h3 class="font-[var(--font-heading)] text-base font-bold text-white leading-snug">{section.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="py-24" style="background-color: #221610;">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-2xl aspect-square">
            <img src={`${base}/images/science/roasting.jpg`} alt="Roasting" class="w-full h-full object-cover" />
          </div>
          <div class="absolute -bottom-5 -right-5 hidden md:block">
            <div class="rounded-2xl p-6 text-white shadow-2xl" style="background-color: #bd490f; max-width: 200px;">
              <p class="text-sm font-[var(--font-heading)] italic leading-snug">"Listen to the bean, adjust by the second. That's what roasting is."</p>
            </div>
          </div>
        </div>
        <div class="text-white">
          <p class="text-xs font-bold tracking-widest uppercase mb-4" style="color: #bd490f;">Deep Dive</p>
          <h2 class="font-[var(--font-heading)] text-4xl font-bold mb-6 leading-tight">
            Why is coffee<br />
            <span style="color: #bd490f;">so complex?</span>
          </h2>
          <p class="text-white/55 mb-10 leading-relaxed text-lg">
            Coffee contains over 1,000 aromatic compounds — more complex than wine. Explore it through science, origin, and craft.
          </p>
          <div class="space-y-7">
            {[
              { title: 'Terroir', desc: 'Soil, altitude, climate — each origin produces a unique flavor.' },
              { title: 'Chemistry of Roasting', desc: 'Maillard reaction, caramelization — heat unlocks complexity.' },
              { title: 'Physics of Extraction', desc: 'Temperature, grind, time — balance creates the perfect cup.' },
            ].map((item) => (
              <div class="flex gap-5">
                <div class="w-2 h-2 rounded-full mt-2.5 shrink-0" style="background-color: #bd490f;" />
                <div>
                  <h5 class="font-bold text-white mb-1">{item.title}</h5>
                  <p class="text-white/45 text-sm leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-[var(--color-background)]">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 class="font-[var(--font-heading)] text-3xl md:text-4xl font-bold text-[var(--color-dark)] mb-4">Where will you start?</h2>
      <p class="text-[var(--color-text-muted)] mb-10 max-w-md mx-auto leading-relaxed">
        Start with origins, the science, or jump straight to brewing recipes.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <a href={`${base}/${lang}/origins`} class="px-8 py-3 rounded-xl font-bold text-white transition-all hover:brightness-110" style="background-color: #bd490f;">Explore Origins</a>
        <a href={`${base}/${lang}/science`} class="px-8 py-3 rounded-xl font-semibold border-2 border-[var(--color-border)] text-[var(--color-dark)] hover:border-[#bd490f] transition-all">Study the Science</a>
        <a href={`${base}/${lang}/tools`} class="px-8 py-3 rounded-xl font-semibold border-2 border-[var(--color-border)] text-[var(--color-dark)] hover:border-[#bd490f] transition-all">Use the Calculator</a>
      </div>
    </div>
  </section>

</BaseLayout>
