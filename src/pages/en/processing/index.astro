---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Decorations from '../../../components/Decorations.astro';

const lang = 'en';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const articles = [
  {
    slug: 'washed',
    title: 'Washed',
    titleEn: 'Washed / Wet Process',
    description: 'Pulp removed, fermented in water, washed clean. The method known for clarity and bright acidity. Widely used in Ethiopia, Kenya, and Colombia.',
    color: 'from-blue-900/10 to-cyan-900/5',
    image: `${base}/images/processing/washed.jpg`,
    ready: true,
  },
  {
    slug: 'natural',
    title: 'Natural',
    titleEn: 'Natural / Dry Process',
    description: 'The oldest method — drying the whole cherry intact. Creates fruity, fermented complexity. Common in Ethiopia and Brazil.',
    color: 'from-orange-900/10 to-amber-900/5',
    image: `${base}/images/processing/natural.jpg`,
    ready: true,
  },
  {
    slug: 'honey',
    title: 'Honey',
    titleEn: 'Honey / Pulped Natural',
    description: 'Pulp removed but mucilage left on during drying. A middle ground between washed and natural in flavor profile.',
    color: 'from-yellow-900/10 to-amber-900/5',
    image: `${base}/images/processing/natural.jpg`,
    ready: true,
  },
  {
    slug: 'experimental',
    title: 'Experimental',
    titleEn: 'Experimental Processing',
    description: 'Anaerobic fermentation, carbonic maceration — the cutting-edge techniques at the frontier of specialty coffee.',
    color: 'from-purple-900/10 to-pink-900/5',
    image: `${base}/images/processing/washed.jpg`,
    ready: true,
  },
];
---

<BaseLayout lang={lang} currentPath={`/${lang}/processing`}>
  <div class="mb-12">
    <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-xl mb-2 rotate-[-1deg]">
      Processing Methods
    </p>
    <h1 class="text-4xl md:text-5xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] leading-tight mb-4">
      Processing Methods
    </h1>
    <p class="text-lg text-[var(--color-text-light)] max-w-2xl leading-relaxed">
      How harvested coffee cherries are processed is one of the biggest factors shaping cup flavor,
      alongside terroir. Understand the differences between washed, natural, and honey processes.
    </p>
  </div>

  <Decorations type="divider" />

  <div class="space-y-5">
    {articles.map((article) => (
      <a
        href={article.ready ? `${base}/${lang}/processing/${article.slug}` : undefined}
        class:list={[
          'block group rounded-2xl border border-[var(--color-border)] overflow-hidden transition-all duration-300',
          `bg-gradient-to-r ${article.color}`,
          article.ready
            ? 'hover:shadow-xl hover:-translate-y-1 cursor-pointer'
            : 'opacity-50 cursor-default',
        ]}
      >
        <div class="flex flex-col md:flex-row">
          <div class="md:w-48 h-36 md:h-auto overflow-hidden flex-shrink-0">
            <img
              src={article.image}
              alt={article.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="flex-1 p-6 md:p-8 flex flex-col md:flex-row md:items-center gap-5">
            <div class="flex-1">
              <p class="font-[var(--font-accent)] text-[var(--color-secondary)] text-sm mb-1">{article.titleEn}</p>
              <h2 class="text-xl md:text-2xl font-bold font-[var(--font-heading)] text-[var(--color-primary)] group-hover:text-[var(--color-accent)] transition-colors mb-2">
                {article.title}
              </h2>
              <p class="text-[var(--color-text-light)] text-sm leading-relaxed">{article.description}</p>
            </div>
            {!article.ready && (
              <span class="text-xs px-3 py-1 rounded-full bg-[var(--color-secondary)]/15 text-[var(--color-text-light)] border border-[var(--color-secondary)]/20 shrink-0">
                Coming Soon
              </span>
            )}
            {article.ready && (
              <svg class="w-5 h-5 text-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-all shrink-0 hidden md:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            )}
          </div>
        </div>
      </a>
    ))}
  </div>
</BaseLayout>
