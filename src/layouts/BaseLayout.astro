---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';
import GSAPAnimations from '../components/GSAPAnimations.astro';
import ClientRouter from 'astro/components/ClientRouter.astro';
import { t, type Lang } from '../i18n';

interface Props {
  title?: string;
  lang: Lang;
  currentPath: string;
  fullWidth?: boolean;
}

const { title, lang, currentPath, fullWidth = false } = Astro.props;
const siteTitle = t(lang, 'site.title');
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const description = t(lang, 'site.description');
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700;900&family=Manrope:wght@300;400;600;800&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Scroll progress bar (persists across VT page swaps) -->
    <div id="scroll-progress-bar" transition:persist></div>

    <!-- Custom cursor — desktop only, persists across VT -->
    <CustomCursor />

    <!-- GSAP ScrollTrigger animations -->
    <GSAPAnimations />

    <Header lang={lang} currentPath={currentPath} />
    <main class:list={['flex-1', !fullWidth && 'max-w-5xl mx-auto w-full px-6 py-12']}>
      <slot />
    </main>
    <Footer lang={lang} />

    <script>
      // ─── Scroll Progress (lightweight, stays in BaseLayout) ───────────
      function updateProgress() {
        const bar = document.getElementById('scroll-progress-bar');
        if (!bar) return;
        const total = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = total > 0 ? `${(window.scrollY / total) * 100}%` : '0%';
      }
      window.addEventListener('scroll', updateProgress, { passive: true });

      // ─── Magnetic Buttons ─────────────────────────────────────────────
      function initMagnetic() {
        document.querySelectorAll('.magnetic').forEach((el) => {
          const h = el as HTMLElement;
          el.addEventListener('mousemove', (e) => {
            const me = e as MouseEvent;
            const r  = h.getBoundingClientRect();
            const dx = me.clientX - (r.left + r.width  / 2);
            const dy = me.clientY - (r.top  + r.height / 2);
            h.style.transition = 'transform 0.12s ease-out';
            h.style.transform  = `translate(${dx * 0.32}px, ${dy * 0.32}px)`;
          });
          el.addEventListener('mouseleave', () => {
            h.style.transition = 'transform 0.55s cubic-bezier(0.34,1.56,0.64,1)';
            h.style.transform  = 'translate(0,0)';
          });
        });
      }

      // ─── Card 3D Tilt ─────────────────────────────────────────────────
      function initCardTilt() {
        document.querySelectorAll('.card-tilt').forEach((el) => {
          const h = el as HTMLElement;
          el.addEventListener('mousemove', (e) => {
            const me = e as MouseEvent;
            const r  = h.getBoundingClientRect();
            const dx = ((me.clientX - r.left) / r.width  - 0.5) * 2;
            const dy = ((me.clientY - r.top)  / r.height - 0.5) * 2;
            h.style.transform  = `perspective(900px) rotateY(${dx * 3}deg) rotateX(${-dy * 2.5}deg) translateZ(6px)`;
            h.style.transition = 'transform 0.08s ease-out';
          });
          el.addEventListener('mouseleave', () => {
            h.style.transform  = 'perspective(900px) rotateY(0deg) rotateX(0deg) translateZ(0)';
            h.style.transition = 'transform 0.6s cubic-bezier(0.34,1.56,0.64,1)';
          });
        });
      }

      // ─── Boot on every page (initial + VT navigations) ────────────────
      document.addEventListener('astro:page-load', () => {
        updateProgress();
        initMagnetic();
        initCardTilt();
      });
    </script>
  </body>
</html>
