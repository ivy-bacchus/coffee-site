---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CustomCursor from '../components/CustomCursor.astro';
import ClientRouter from 'astro/components/ClientRouter.astro';
import { t, type Lang } from '../i18n';

interface Props {
  title?: string;
  lang: Lang;
  currentPath: string;
  fullWidth?: boolean;
}

const { title, lang, currentPath, fullWidth = false } = Astro.props;
const siteTitle = t(lang, 'site.title');
const pageTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const description = t(lang, 'site.description');
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700;900&family=Manrope:wght@300;400;600;800&display=swap" rel="stylesheet" />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Scroll progress bar -->
    <div id="scroll-progress-bar" transition:persist></div>

    <!-- Custom cursor (desktop only) -->
    <CustomCursor />

    <Header lang={lang} currentPath={currentPath} />
    <main class:list={['flex-1', !fullWidth && 'max-w-5xl mx-auto w-full px-6 py-12']}>
      <slot />
    </main>
    <Footer lang={lang} />

    <script>
      // ─── Module-level state (persists across VT navigations) ──────────
      let revealObserver: IntersectionObserver | null = null;
      let parallaxEls: { el: HTMLElement; factor: number }[] = [];

      // ─── Scroll Progress ──────────────────────────────────────────────
      function updateProgress() {
        const bar = document.getElementById('scroll-progress-bar');
        if (!bar) return;
        const total = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = total > 0 ? `${(window.scrollY / total) * 100}%` : '0%';
      }

      // ─── Parallax update ──────────────────────────────────────────────
      function updateParallax() {
        const sy = window.scrollY;
        parallaxEls.forEach(({ el, factor }) => {
          el.style.transform = `translateY(${sy * factor}px)`;
        });
      }

      // One-time scroll listener (handles both progress + parallax)
      window.addEventListener('scroll', () => {
        updateProgress();
        updateParallax();
      }, { passive: true });

      // ─── Scroll Reveal ────────────────────────────────────────────────
      function initReveal() {
        if (revealObserver) revealObserver.disconnect();
        revealObserver = new IntersectionObserver(
          (entries) => entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
              revealObserver!.unobserve(e.target);
            }
          }),
          { threshold: 0.08, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal,.reveal-left,.reveal-right,.reveal-scale,.reveal-blur')
          .forEach((el) => revealObserver!.observe(el));
      }

      // ─── Text Split ───────────────────────────────────────────────────
      // Wraps each character of [data-split-text] headings in animated spans
      function initTextSplit() {
        document.querySelectorAll('[data-split-text]').forEach((el) => {
          if (el.getAttribute('data-split-done')) return;
          el.setAttribute('data-split-done', '1');
          let idx = 0;

          function processNode(node: Node) {
            if (node.nodeType === Node.TEXT_NODE) {
              const chars = [...(node.textContent || '')];
              const frag = document.createDocumentFragment();
              chars.forEach((ch) => {
                if (!ch.trim() || ch === '\n') {
                  frag.appendChild(document.createTextNode(ch));
                } else {
                  const span = document.createElement('span');
                  span.className = 'split-char';
                  span.style.animationDelay = `${idx * 0.038}s`;
                  span.textContent = ch;
                  frag.appendChild(span);
                  idx++;
                }
              });
              node.parentNode!.replaceChild(frag, node);
            } else if (node.nodeType === Node.ELEMENT_NODE) {
              [...node.childNodes].forEach(processNode);
            }
          }

          processNode(el);
        });
      }

      // ─── Parallax ─────────────────────────────────────────────────────
      function initParallax() {
        parallaxEls = [...document.querySelectorAll('[data-parallax]')].map((el) => ({
          el: el as HTMLElement,
          factor: parseFloat((el as HTMLElement).dataset.parallax || '0.12'),
        }));
        updateParallax();
      }

      // ─── Magnetic Buttons ─────────────────────────────────────────────
      function initMagnetic() {
        document.querySelectorAll('.magnetic').forEach((el) => {
          const h = el as HTMLElement;
          el.addEventListener('mousemove', (e) => {
            const me = e as MouseEvent;
            const r  = h.getBoundingClientRect();
            const dx = me.clientX - (r.left + r.width  / 2);
            const dy = me.clientY - (r.top  + r.height / 2);
            h.style.transition = 'transform 0.12s ease-out';
            h.style.transform  = `translate(${dx * 0.32}px, ${dy * 0.32}px)`;
          });
          el.addEventListener('mouseleave', () => {
            h.style.transition = 'transform 0.55s cubic-bezier(0.34,1.56,0.64,1)';
            h.style.transform  = 'translate(0,0)';
          });
        });
      }

      // ─── Card 3D Tilt ─────────────────────────────────────────────────
      function initCardTilt() {
        document.querySelectorAll('.card-tilt').forEach((el) => {
          const h = el as HTMLElement;
          el.addEventListener('mousemove', (e) => {
            const me = e as MouseEvent;
            const r  = h.getBoundingClientRect();
            const dx = ((me.clientX - r.left) / r.width  - 0.5) * 2;
            const dy = ((me.clientY - r.top)  / r.height - 0.5) * 2;
            h.style.transform  = `perspective(900px) rotateY(${dx * 3}deg) rotateX(${-dy * 2.5}deg) translateZ(6px)`;
            h.style.transition = 'transform 0.08s ease-out';
          });
          el.addEventListener('mouseleave', () => {
            h.style.transform  = 'perspective(900px) rotateY(0deg) rotateX(0deg) translateZ(0)';
            h.style.transition = 'transform 0.6s cubic-bezier(0.34,1.56,0.64,1)';
          });
        });
      }

      // ─── Boot on every page load (initial + VT navigations) ──────────
      document.addEventListener('astro:page-load', () => {
        updateProgress();
        initReveal();
        initTextSplit();
        initParallax();
        initMagnetic();
        initCardTilt();
      });
    </script>
  </body>
</html>
