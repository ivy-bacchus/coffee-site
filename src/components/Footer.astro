---
import { type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="mt-20 w-full" style="border-top: 1px solid rgba(212,195,191,0.3); background-color: #faf9f6;">
  <div class="max-w-screen-2xl mx-auto px-8 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start gap-12 mb-10">
      <!-- Brand -->
      <div>
        <p class="text-xl font-black italic" style="font-family: 'Noto Serif JP', serif; color: #361f1a;">
          The Elevated Alchemist
        </p>
        <p class="text-sm mt-2 leading-relaxed max-w-xs" style="color: #504442;">
          {lang === 'ja'
            ? 'スペシャルティコーヒーの科学と感性が交差する場所。'
            : 'Where the science and sensibility of specialty coffee converge.'}
        </p>
      </div>

      <!-- Links -->
      <div class="flex gap-16">
        <div>
          <h5 class="text-xs font-bold uppercase tracking-widest mb-4" style="color: #361f1a; font-family: Manrope, sans-serif;">
            {lang === 'ja' ? 'コンテンツ' : 'Content'}
          </h5>
          <ul class="space-y-2.5 text-sm" style="color: #504442;">
            <li><a href={`${base}/${lang}/origins`} class="hover:text-[#361f1a] transition-colors">{lang === 'ja' ? '産地・農園' : 'Origins'}</a></li>
            <li><a href={`${base}/${lang}/brewing`} class="hover:text-[#361f1a] transition-colors">{lang === 'ja' ? '抽出ガイド' : 'Brewing Guide'}</a></li>
            <li><a href={`${base}/${lang}/science`} class="hover:text-[#361f1a] transition-colors">{lang === 'ja' ? 'コーヒーの化学' : 'Coffee Science'}</a></li>
            <li><a href={`${base}/${lang}/processing`} class="hover:text-[#361f1a] transition-colors">{lang === 'ja' ? '精製プロセス' : 'Processing'}</a></li>
            <li><a href={`${base}/${lang}/tools`} class="hover:text-[#361f1a] transition-colors">{lang === 'ja' ? 'レシピ計算機' : 'Calculator'}</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8" style="border-top: 1px solid rgba(212,195,191,0.3);">
      <p class="text-xs italic" style="color: #827471; font-family: 'Noto Serif JP', serif;">
        © 2026 The Elevated Alchemist | Digital Sommelier Archive
      </p>
      <p class="text-xs uppercase tracking-widest" style="color: #d4c3bf; font-family: Manrope, sans-serif;">
        Powered by curiosity & caffeine.
      </p>
    </div>
  </div>
</footer>
