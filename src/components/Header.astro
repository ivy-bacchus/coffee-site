---
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navItems = [
  { key: 'origins',    href: `${base}/${lang}/origins` },
  { key: 'brewing',    href: `${base}/${lang}/brewing` },
  { key: 'science',    href: `${base}/${lang}/science` },
  { key: 'processing', href: `${base}/${lang}/processing` },
  { key: 'tools',      href: `${base}/${lang}/tools` },
];

const normalizedCurrent = `${base}${currentPath}`;
---

<header class="fixed top-0 z-50 w-full backdrop-blur-md" style="background-color: rgba(250,249,246,0.88); border-bottom: 1px solid rgba(212,195,191,0.4); box-shadow: 0 20px 40px rgba(26,28,26,0.04);">
  <div class="max-w-screen-2xl mx-auto px-8 h-16 flex items-center justify-between gap-8">

    <!-- Logo -->
    <a href={`${base}/${lang}`} class="shrink-0">
      <span class="text-xl font-black italic tracking-tight" style="font-family: 'Noto Serif JP', serif; color: #361f1a;">
        The Elevated Alchemist
      </span>
    </a>

    <!-- Nav — desktop -->
    <nav class="hidden md:flex items-center gap-10">
      {navItems.map((item) => {
        const isActive = normalizedCurrent === item.href ||
          (item.key !== 'home' && normalizedCurrent.startsWith(item.href));
        return (
          <a
            href={item.href}
            class="text-sm transition-colors duration-200"
            style={isActive
              ? 'color: #361f1a; border-bottom: 2px solid #456555; padding-bottom: 2px; font-family: Noto Serif JP, serif;'
              : 'color: #504442; font-family: Noto Serif JP, serif;'}
          >
            {t(lang, `nav.${item.key}`)}
          </a>
        );
      })}
    </nav>

    <!-- Right: Lang toggle + hamburger -->
    <div class="flex items-center gap-4 shrink-0">
      <!-- Language Toggle -->
      <div class="flex rounded-full overflow-hidden text-xs font-bold border" style="border-color: rgba(212,195,191,0.6);">
        <a
          href={currentPath.replace(`/${lang}`, `${base}/ja`)}
          class="px-3 py-1.5 transition-colors"
          style={lang === 'ja'
            ? 'background-color: #361f1a; color: #ffffff;'
            : 'color: #827471;'}
        >JA</a>
        <a
          href={currentPath.replace(`/${lang}`, `${base}/en`)}
          class="px-3 py-1.5 transition-colors"
          style={lang === 'en'
            ? 'background-color: #361f1a; color: #ffffff;'
            : 'color: #827471;'}
        >EN</a>
      </div>

      <!-- Mobile hamburger -->
      <button id="mobile-menu-btn" class="md:hidden p-1.5" aria-label="Menu" style="color: #504442;">
        <svg id="menu-open-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="menu-close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden" style="background-color: #faf9f6; border-top: 1px solid rgba(212,195,191,0.4);">
    <nav class="px-8 py-4 flex flex-col gap-1">
      {navItems.map((item) => {
        const isActive = normalizedCurrent === item.href || normalizedCurrent.startsWith(item.href);
        return (
          <a
            href={item.href}
            class="px-3 py-2.5 text-sm transition-colors"
            style={isActive
              ? 'color: #361f1a; font-weight: 700; font-family: Noto Serif JP, serif;'
              : 'color: #504442; font-family: Noto Serif JP, serif;'}
          >
            {t(lang, `nav.${item.key}`)}
          </a>
        );
      })}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn')!;
  const menu = document.getElementById('mobile-menu')!;
  const openIcon = document.getElementById('menu-open-icon')!;
  const closeIcon = document.getElementById('menu-close-icon')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    openIcon.classList.toggle('hidden', !isOpen);
    closeIcon.classList.toggle('hidden', isOpen);
  });
</script>
